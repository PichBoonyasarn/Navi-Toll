GOOGLE_MAPS_KEY=your_google_maps_api_key_here
COMPANY_ADDRESS=〒617-0856 Kyoto, Nagaokakyo, 金ヶ原Susaki−６−番地１
PORT=3000
# Optional: enables OCR fallback for image-based/scanned PDFs with no text
# layer. Get a free key at https://aistudio.google.com/apikey — if unset,
# those documents just report "no coordinates found" as before.
GEMINI_API_KEY=your_gemini_api_key_here
# Required for route/toll/IC lookup in this fork - get a free key (BASIC
# plan, 500 requests/month) at
# https://rapidapi.com/navitimejapan-navitimejapan/api/navitime-route-car
NAVITIME_API_KEY=your_rapidapi_key_here
